generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String
  notes    Note[]

  @@map("users")
}

model Note {
  id      Int     @id @default(autoincrement())
  title   String?
  content String?
  tag     String?
  userId  Int     @map("user_id")
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notes")
}
